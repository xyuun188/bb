# ============================================
# AI Crypto Trading System - Environment Config
# ============================================

# --- OKX Exchange ---
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_DEMO=true

# --- AI API (OpenAI-compatible) ---
AI_API_BASE=https://yjxapi.top/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4

# --- Database ---
# SQLite for development (default)
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading

# --- Redis ---
# Use fakeredis for development (no external Redis needed)
REDIS_URL=redis://localhost:6379/0
USE_FAKEREDIS=true

# --- Trading Parameters ---
TRADING_MODE=paper
SYMBOLS=["BTC/USDT","ETH/USDT","SOL/USDT"]
INITIAL_VIRTUAL_BALANCE=100000.0
DECISION_INTERVAL_SECONDS=60
AUTO_SCAN_SYMBOL_LIMIT=20
MAX_AUTO_TRADES_PER_ROUND=8
MIN_ENTRY_ADX=15
MIN_ENTRY_VOLUME_RATIO=0.2
DAILY_PROFIT_TARGET_USDT=1000
DAILY_PROFIT_TARGET_CNY=0
CNY_PER_USDT_ASSUMPTION=7.2

# --- Risk Management ---
MAX_POSITION_PCT=0.25
MAX_LEVERAGE=20.0
MAX_DAILY_LOSS_PCT=0.05
MAX_SLIPPAGE_PCT=0.005
HARD_STOP_LOSS_PCT=0.05
TRAILING_STOP_ACTIVATION=0.03
TRAILING_STOP_DISTANCE=0.015

# --- Web Dashboard ---
DASHBOARD_PORT=8002
DASHBOARD_HOST=0.0.0.0

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DINGTALK_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/trading.log
